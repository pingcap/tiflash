# Reproducer for O11Y-2580066 / shared-lock FK check + long parent WritePut (>255 bytes).
#   1. parent/child with FK; only parent has TiFlash replica.
#   2. Seed parent(id=1).
#   3. Pessimistic txn: INSERT child -> FK shared lock on parent(1);
#      INSERT parent(id=2, big_v=REPEAT('x',512)) in the same txn.
#   4. Read back from TiKV, then from TiFlash.
# Unfixed proxy (e.g. tiflash-proxy-next-gen 66199984c): TiFlash read fails; log may show
#   "can not found in default cf". Fixed proxy should match TiKV output below.

mysql> drop table if exists test.fk_child;
mysql> drop table if exists test.fk_parent;
mysql> create table test.fk_parent (id bigint primary key, v varchar(32) not null, big_v varchar(1024) not null default '');
mysql> create table test.fk_child (id bigint primary key, parent_id bigint not null, v varchar(32) not null default '', constraint fk_child_parent foreign key (parent_id) references test.fk_parent (id));
mysql> alter table test.fk_parent set tiflash replica 1;

func> wait_table test fk_parent

mysql> set @@session.foreign_key_checks = on; set @@session.tidb_foreign_key_check_in_shared_lock = on; insert into test.fk_parent (id, v, big_v) values (1, 'p1', 'seed');

# written in one line so that `tests/run-test.py` could execute all the DML in the same txn
# turn off fair locking because these two features are conflict
mysql> set @@session.foreign_key_checks = on; set @@session.tidb_foreign_key_check_in_shared_lock = on; set @@session.tidb_pessimistic_txn_fair_locking = off; begin pessimistic; insert into test.fk_child (id, parent_id, v) values (1, 1, 'c1'); insert into test.fk_parent (id, v, big_v) values (2, 'p2', repeat('x', 512)); commit;

mysql> set session tidb_isolation_read_engines='tikv'; select id, length(big_v) as big_v_bytes from test.fk_parent order by id;
+----+-------------+
| id | big_v_bytes |
+----+-------------+
|  1 |           4 |
|  2 |         512 |
+----+-------------+

mysql> set session tidb_isolation_read_engines='tiflash'; select id, length(big_v) as big_v_bytes from test.fk_parent order by id;
+----+-------------+
| id | big_v_bytes |
+----+-------------+
|  1 |           4 |
|  2 |         512 |
+----+-------------+

mysql> drop table if exists test.fk_child;
mysql> drop table if exists test.fk_parent;
