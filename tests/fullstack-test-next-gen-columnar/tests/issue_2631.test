# Regression test for tidbcloud/tidb-cse#2631.
# The minimal textSearch projection must return the original clustered VARCHAR
# primary key bytes, not collation-key bytes.

mysql> set global tidb_enable_fulltext_index = 1;
mysql> drop database if exists fts_common_handle_pk;
mysql> create database fts_common_handle_pk;
mysql> create table fts_common_handle_pk.fts_repro_min (
   pk_text varchar(14) collate utf8mb4_0900_ai_ci not null,
   tenant_id int default null,
   body varchar(3000) collate utf8mb4_0900_ai_ci default null,
   primary key (pk_text) clustered,
   fulltext index ft_body (body) with parser standard
   ) engine=InnoDB default charset=utf8mb4 collate=utf8mb4_0900_ai_ci;
mysql> insert into fts_common_handle_pk.fts_repro_min (pk_text, tenant_id, body) values ('id000000000001', 1, 'Note');

mysql> select hex(pk_text), pk_text from fts_common_handle_pk.fts_repro_min where fts_match_word('+Note*', body);
+------------------------------+----------------+
| hex(pk_text)                 | pk_text        |
+------------------------------+----------------+
| 6964303030303030303030303031 | id000000000001 |
+------------------------------+----------------+

mysql> select hex(pk_text), pk_text, tenant_id from fts_common_handle_pk.fts_repro_min where fts_match_word('+Note*', body);
+------------------------------+----------------+-----------+
| hex(pk_text)                 | pk_text        | tenant_id |
+------------------------------+----------------+-----------+
| 6964303030303030303030303031 | id000000000001 |         1 |
+------------------------------+----------------+-----------+

mysql> drop database if exists fts_common_handle_pk;
