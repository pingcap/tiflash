mysql> drop table if exists test.unary_minus;
mysql> create table test.unary_minus(id int primary key, i bigint, u bigint unsigned, f double, d decimal(10, 2));
mysql> alter table test.unary_minus set tiflash replica 1;
mysql> insert into test.unary_minus values (1, 4, 4, 1.25, 1.23), (2, -5, 5, -3.5, -4.56), (3, 500000000000000000, 9223372036854775808, 2.5, 0.00), (4, null, null, null, null);

func> wait_table test unary_minus

mysql> set @@tidb_isolation_read_engines='tiflash'; set tidb_enforce_mpp=1; select id, -i as neg_i from test.unary_minus order by id;
+----+---------------------+
| id | neg_i               |
+----+---------------------+
|  1 |                  -4 |
|  2 |                   5 |
|  3 | -500000000000000000 |
|  4 |                NULL |
+----+---------------------+

mysql> set @@tidb_isolation_read_engines='tiflash'; set tidb_enforce_mpp=1; select id, -u as neg_u from test.unary_minus order by id;
+----+----------------------+
| id | neg_u                |
+----+----------------------+
|  1 |                   -4 |
|  2 |                   -5 |
|  3 | -9223372036854775808 |
|  4 |                 NULL |
+----+----------------------+

mysql> set @@tidb_isolation_read_engines='tiflash'; set tidb_enforce_mpp=1; select id, -f as neg_f from test.unary_minus order by id;
+----+-------+
| id | neg_f |
+----+-------+
|  1 | -1.25 |
|  2 |   3.5 |
|  3 |  -2.5 |
|  4 |  NULL |
+----+-------+

mysql> set @@tidb_isolation_read_engines='tiflash'; set tidb_enforce_mpp=1; select id, -d as neg_d from test.unary_minus order by id;
+----+-------+
| id | neg_d |
+----+-------+
|  1 | -1.23 |
|  2 |  4.56 |
|  3 |  0.00 |
|  4 |  NULL |
+----+-------+

mysql> set @@tidb_isolation_read_engines='tiflash'; set tidb_enforce_mpp=1; select id from test.unary_minus where -u = -5 order by id;
+----+
| id |
+----+
|  2 |
+----+

mysql> drop table if exists test.unary_minus;
