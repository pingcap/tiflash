mysql> drop table if exists test.t_issue10809_varchar_null;
mysql> drop table if exists test.t_issue10809_varchar_empty;

# Negative regressions for #10809 on StringV2-backed SQL types.
# Unlike Nullable(Array(...)), nullable varchar values and empty strings should
# not trigger compact-time crashes in TiFlash.

mysql> create table test.t_issue10809_varchar_null (`id` int primary key, `v` varchar(32) default null);
mysql> alter table test.t_issue10809_varchar_null set tiflash replica 1;
mysql> insert into test.t_issue10809_varchar_null with recursive seq as (select 1 as n union all select n + 1 from seq where n < 128) select n, null from seq;
func> wait_table test t_issue10809_varchar_null

mysql> alter table test.t_issue10809_varchar_null compact tiflash replica;
mysql> set session tidb_isolation_read_engines='tiflash'; select count(*), count(v) from test.t_issue10809_varchar_null;
+----------+----------+
| count(*) | count(v) |
+----------+----------+
|      128 |        0 |
+----------+----------+

mysql> create table test.t_issue10809_varchar_empty (`id` int primary key, `v` varchar(32) not null);
mysql> alter table test.t_issue10809_varchar_empty set tiflash replica 1;
mysql> insert into test.t_issue10809_varchar_empty with recursive seq as (select 1 as n union all select n + 1 from seq where n < 128) select n, '' from seq;
func> wait_table test t_issue10809_varchar_empty

mysql> alter table test.t_issue10809_varchar_empty compact tiflash replica;
mysql> set session tidb_isolation_read_engines='tiflash'; select count(*), sum(length(v)) from test.t_issue10809_varchar_empty;
+----------+----------------+
| count(*) | sum(length(v)) |
+----------+----------------+
|      128 |              0 |
+----------+----------------+

mysql> drop table if exists test.t_issue10809_varchar_null;
mysql> drop table if exists test.t_issue10809_varchar_empty;
