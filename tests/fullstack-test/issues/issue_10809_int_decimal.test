mysql> drop table if exists test.t_issue10809_int;
mysql> drop table if exists test.t_issue10809_decimal;

# These are negative regressions for #10809.
# The issue is specific to Nullable(Array(...)) data, but compacting TiFlash
# replicas for ordinary nullable scalar types should continue to work.

mysql> create table test.t_issue10809_int (`id` int primary key, `v` int default null);
mysql> alter table test.t_issue10809_int set tiflash replica 1;
mysql> insert into test.t_issue10809_int with recursive seq as (select 1 as n union all select n + 1 from seq where n < 128) select n, null from seq;
func> wait_table test t_issue10809_int

mysql> alter table test.t_issue10809_int compact tiflash replica;
mysql> set session tidb_isolation_read_engines='tiflash'; select count(*), count(v) from test.t_issue10809_int;
+----------+----------+
| count(*) | count(v) |
+----------+----------+
|      128 |        0 |
+----------+----------+

mysql> create table test.t_issue10809_decimal (`id` int primary key, `v` decimal(20,6) default null);
mysql> alter table test.t_issue10809_decimal set tiflash replica 1;
mysql> insert into test.t_issue10809_decimal with recursive seq as (select 1 as n union all select n + 1 from seq where n < 128) select n, null from seq;
func> wait_table test t_issue10809_decimal

mysql> alter table test.t_issue10809_decimal compact tiflash replica;
mysql> set session tidb_isolation_read_engines='tiflash'; select count(*), count(v) from test.t_issue10809_decimal;
+----------+----------+
| count(*) | count(v) |
+----------+----------+
|      128 |        0 |
+----------+----------+

mysql> drop table if exists test.t_issue10809_int;
mysql> drop table if exists test.t_issue10809_decimal;
